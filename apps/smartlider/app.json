{
  "expo": {
    "name": "SmartLider",
    "slug": "smartlider",
    "version": "1.0.6",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0B1A3B"
    },
    "scheme": "smartlider",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.smartpro.smartlider"
    },
    "android": {
      "package": "br.smartpro.smartlider",
      "versionCode": 29,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite selecionar imagens para importar mapas de campo."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite tirar fotos de apontamentos"
        }
      ],
      [
        "expo-location",
        {
        "locationAlwaysAndWhenInUsePermission": "Permite mostrar sua posição nos mapas de campo e registrar a jornada de trabalho.",
          "locationAlwaysUsageDescription": "Necessário para registrar o trajeto em campo mesmo com a tela bloqueada.",
          "locationWhenInUseUsageDescription": "Permite exibir sua posição no mapa de campo."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 36,
            "compileSdkVersion": 36,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      ["./plugins/withAbiFilters", { "abiFilters": ["arm64-v8a", "armeabi-v7a"] }],
      ["./plugins/withSplashBackground", { "color": "#0B1A3B" }],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyDummyKeyReplaceWithRealKey"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "paulo_martins",
    "runtimeVersion": "exposdk:56.0.0",
    "updates": {
      "url": "https://u.expo.dev/1f379ffd-098a-4c7c-aa93-b729ed5dfdda",
      "enabled": true,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f379ffd-098a-4c7c-aa93-b729ed5dfdda"
      }
    }
  }
}
